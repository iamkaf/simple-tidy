{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": [
    "${mod_author}"
  ],
  "contact": {
    "sources": "https://github.com/iamkaf/simple-sort"
  },
  "license": "${license}",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.iamkaf.simplesort.fabric.FabricEntrypoint"
    ]
  },
  "mixins": [
    "${mod_id}.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": "*",
    "amber": "*",
    "minecraft": "${fabric_version_range}",
    "java": ">=${java_version}"
  }
}
